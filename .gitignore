# =====================================
# Git 忽略文件配置
# 按类别组织，添加中文注释
# =====================================

# =====================
# 操作系统相关
# =====================
# macOS 系统文件
.DS_Store

# Windows 系统文件
Thumbs.db

# =====================
# 前端项目相关
# =====================
# Node.js 依赖目录
node_modules/

# 构建产物
dist/
build/

# 前端环境变量文件
.env.local
.env.*.local

# 前端日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =====================
# 后端项目相关（Java）
# =====================
# 编译产物
*.class
target/

# 包文件
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# 运行时日志
*.log

# JVM 崩溃日志
# 参考: http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

# 本地配置文件（包含敏感信息）
src/main/resources/application-dev.yml

